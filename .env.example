# ── NanoClaw core ─────────────────────────────────────────────────────────────
ASSISTANT_NAME=Andy
ASSISTANT_HAS_OWN_NUMBER=false
TZ=Europe/Paris

# ── Microsoft 365 (Outlook Mail + Calendar) ───────────────────────────────────
# Créer une App Registration sur https://portal.azure.com
# Permissions requises : Mail.Read, Mail.ReadWrite, Mail.Send, Calendars.Read, Calendars.ReadWrite
MICROSOFT_CLIENT_ID=
MICROSOFT_TENANT_ID=consumers

# JID WhatsApp pour recevoir les résumés d'agenda (ex: 33612345678@s.whatsapp.net)
CALENDAR_NOTIFY_JID=

# ── Veille professionnelle (RSS) ───────────────────────────────────────────────
# URLs de flux RSS séparées par des virgules
NEWS_FEEDS=https://feeds.lemonde.fr/rss/une,https://www.usine-digitale.fr/feed/
# Heure d'envoi du digest (cron, défaut: 8h00 chaque matin)
NEWS_CRON=0 8 * * *
# Thèmes à surveiller (optionnel)
NEWS_TOPICS=intelligence artificielle,tech,innovation
# JID WhatsApp pour recevoir la veille
NEWS_NOTIFY_JID=
